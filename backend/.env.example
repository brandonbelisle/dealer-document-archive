# ============================================================
# DEALER DOCUMENT ARCHIVE — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.

# Server
PORT=443
HOST=0.0.0.0
NODE_ENV=production

# SSL / HTTPS
# Set SSL_ENABLED=true and run "bash generate-cert.sh" first
SSL_ENABLED=true
SSL_KEY=./ssl/server.key
SSL_CERT=./ssl/server.crt
# Set to true to also start an HTTP server on port 80 that redirects to HTTPS
HTTP_REDIRECT=true

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=dealer_document_archive

# JWT Authentication
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=24h

# File Uploads
MAX_FILE_SIZE_MB=50

# Azure Blob Storage
# Option 1: Connection string (easiest — find in Azure Portal → Storage Account → Access Keys)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=youraccount;AccountKey=yourkey;EndpointSuffix=core.windows.net

# Option 2: Account name + key (alternative to connection string)
# AZURE_STORAGE_ACCOUNT_NAME=youraccount
# AZURE_STORAGE_ACCOUNT_KEY=yourkey

# Container name (created automatically if it doesn't exist)
AZURE_STORAGE_CONTAINER_NAME=documents

# Frontend URL (only needed if frontend is hosted separately)
# FRONTEND_URL=http://localhost:5173

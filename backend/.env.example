# ============================================================
# DEALER DOCUMENT ARCHIVE — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.

# Server
PORT=443
HOST=0.0.0.0
NODE_ENV=production

# SSL / HTTPS
# Set SSL_ENABLED=true and run "bash generate-cert.sh" first
SSL_ENABLED=true
SSL_KEY=./ssl/server.key
SSL_CERT=./ssl/server.crt
# Set to true to also start an HTTP server on port 80 that redirects to HTTPS
HTTP_REDIRECT=true

# Rate Limiting
# Max login/register attempts per 15-minute window
RATE_LIMIT_MAX=10

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=dealer_document_archive

# JWT Authentication (REQUIRED)
# Must be a long random string in production - no default is provided
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=24h

# Security Settings
# Account lockout after too many failed login attempts
MAX_FAILED_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# File Uploads
MAX_FILE_SIZE_MB=50

# Azure Blob Storage
# Option 1: Connection string (easiest — find in Azure Portal → Storage Account → Access Keys)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=youraccount;AccountKey=yourkey;EndpointSuffix=core.windows.net

# Option 2: Account name + key (alternative to connection string)
# AZURE_STORAGE_ACCOUNT_NAME=youraccount
# AZURE_STORAGE_ACCOUNT_KEY=yourkey

# Container name (created automatically if it doesn't exist)
AZURE_STORAGE_CONTAINER_NAME=documents

# Frontend URL (REQUIRED in production for CORS)
# Set this to your frontend's origin for proper CORS configuration
# Development: Vite proxies /api automatically, so this can be left unset
# Production: MUST be set (e.g., https://your-frontend-domain.com)
FRONTEND_URL=http://localhost:5173

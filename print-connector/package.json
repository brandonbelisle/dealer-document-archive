{
  "name": "dda-print-connector",
  "version": "1.0.0",
  "description": "Windows print connector for DDA - watches folder for PDFs and uploads to Dealer Document Archive",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "build": "pkg . --targets node18-win-x64 --output dist/dda-print-connector.exe",
    "build:msi": "npm run build && node scripts/build-msi.js",
    "install-service": "node install-service.js",
    "uninstall-service": "node uninstall-service.js"
  },
  "pkg": {
    "scripts": [
      "index.js",
      "config.js",
      "dda-client.js",
      "watcher.js"
    ],
    "assets": [
      "config/default.json",
      "node_modules/pdf-parse/**/*.js",
      "node_modules/pdf-parse/lib/*.js"
    ],
    "outputPath": "dist"
  },
  "keywords": ["dda", "printer", "pdf", "upload", "windows"],
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.0",
    "chokidar": "^3.6.0",
    "form-data": "^4.0.0",
    "node-notifier": "^10.0.1",
    "node-windows": "^2.0.0",
    "pdf-parse": "^1.1.1",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^5.11.2"
  }
}